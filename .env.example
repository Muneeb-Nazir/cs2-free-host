# Coolify API Configuration
COOLIFY_API_URL=http://localhost:8000/api/v1
COOLIFY_API_TOKEN=your_coolify_api_token_here
CS2_SERVICE_UUID=your_cs2_service_uuid_here

# Server Network
PUBLIC_IP=your.public.ip.address

# Steam Configuration (REQUIRED for public server)
# Get GSLT at: https://steamcommunity.com/dev/managegameservers
STEAM_GSLT=your_steam_gslt_token_here

# Default Server Settings
CS2_SERVERNAME=My Free CS2 Server
CS2_MAXPLAYERS=14
CS2_MAP=de_dust2
CS2_GAMEMODE=0
CS2_GAMETYPE=0
CS2_TICKRATE=64
CS2_PW=
CS2_RCONPW=changeme123

# Auto-Shutdown (false = keep running, true = stop when empty)
AUTO_SHUTDOWN=false
IDLE_TIMEOUT=30